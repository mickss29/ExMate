<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ================================================================
         EXMATE — MASTER THEMES
    ================================================================ -->

    <!-- ── MAIN APP THEME ────────────────────────────────────────────── -->

    <style name="Theme.ExMate" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Brand colors -->
        <item name="colorPrimary">#2B55FF</item>
        <item name="colorPrimaryVariant">#1E2A8A</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#5B8BFF</item>
        <item name="colorOnSecondary">@android:color/white</item>

        <!-- Window / Status bar -->
        <item name="android:windowBackground">#060C1E</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Bottom sheet -->
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.ExMate.BottomSheet</item>

    </style>

    <!-- ── AUTH SCREEN THEME (edge-to-edge) ──────────────────────────── -->

    <style name="Theme.ExMate.Auth" parent="Theme.ExMate">
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <!-- ── DIALOGS ────────────────────────────────────────────────────── -->

    <style name="DarkAlertDialog"
        parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">#0D1530</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="colorAccent">#2B55FF</item>
        <item name="android:editTextColor">#FFFFFF</item>
    </style>

    <!-- ── BOTTOM SHEET ───────────────────────────────────────────────── -->

    <style name="ThemeOverlay.ExMate.BottomSheet"
        parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="android:background">@android:color/transparent</item>
        <item name="bottomSheetStyle">@style/ExMate.BottomSheet</item>
    </style>

    <style name="ExMate.BottomSheet"
        parent="Widget.MaterialComponents.BottomSheet">
        <item name="android:background">@drawable/bg_bottom_sheet</item>
        <item name="shapeAppearance">@style/ExMate.BottomSheetShape</item>
    </style>

    <style name="ExMate.BottomSheetShape"
        parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">28dp</item>
        <item name="cornerSizeTopRight">28dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

</resources>