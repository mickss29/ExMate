<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1120"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HERO HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/profile_hero_gradient"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="52dp"
            android:gravity="center_horizontal">

            <!-- Back row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_back"
                    android:tint="#94A3B8"
                    android:padding="10dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="Edit Profile"
                    android:textColor="#E2E8F0"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Avatar -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginTop="20dp">

                <View
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:background="@drawable/avatar_glow_ring"/>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="35dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="#3B82F6">

                    <TextView
                        android:id="@+id/tvEditAvatarInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="U"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <TextView
                android:id="@+id/tvEditHeaderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Your Name"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvEditHeaderEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="email@example.com"
                android:textColor="#4B6280"
                android:textSize="12sp"/>

        </LinearLayout>

        <!-- ── FORM PANEL ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bottom_sheet_rounded"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="44dp"
            android:layout_marginTop="-24dp">

            <!-- Drag handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="26dp"
                android:background="@drawable/drag_handle_shape"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERSONAL INFO"
                android:textColor="#2D3748"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.15"
                android:layout_marginBottom="14dp"/>

            <!-- Full Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Full Name"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="54dp"
                app:cardBackgroundColor="#111827"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E293B"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="👤"
                        android:gravity="center"
                        android:textSize="16sp"/>

                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:hint="Enter full name"
                        android:background="@null"
                        android:textColor="#E2E8F0"
                        android:textColorHint="#2D3748"
                        android:textSize="14sp"
                        android:inputType="textPersonName"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Phone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phone Number"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="54dp"
                app:cardBackgroundColor="#111827"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E293B"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="📱"
                        android:gravity="center"
                        android:textSize="16sp"/>

                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:hint="Enter phone number"
                        android:background="@null"
                        android:textColor="#E2E8F0"
                        android:textColorHint="#2D3748"
                        android:textSize="14sp"
                        android:inputType="phone"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Email — read-only -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email (read-only)"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginTop="18dp"
                android:layout_marginBottom="6dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="54dp"
                app:cardBackgroundColor="#0D1117"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#1E293B"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="📧"
                        android:gravity="center"
                        android:textSize="16sp"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:background="@null"
                        android:textColor="#2D3748"
                        android:textSize="14sp"
                        android:focusable="false"
                        android:clickable="false"
                        android:inputType="textEmailAddress"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Password hint -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="🔐  You'll confirm your password before saving"
                android:textColor="#2D3748"
                android:textSize="11sp"
                android:gravity="center"/>

            <!-- Save Button -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="28dp"
                app:cardCornerRadius="18dp"
                app:cardElevation="16dp"
                app:cardBackgroundColor="#3B82F6">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <Button
                        android:id="@+id/btnUpdateProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="Save Changes  ✓"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:background="@null"/>

                    <ProgressBar
                        android:id="@+id/progressUpdate"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="#FFFFFF"
                        android:visibility="gone"/>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>