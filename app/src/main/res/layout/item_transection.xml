<?xml version="1.0" encoding="utf-8"?>

<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="20dp"
    android:layout_marginEnd="20dp"
    android:layout_marginBottom="10dp"
    android:layout_marginTop="2dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="#0F1421"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1A2236">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- ── Left accent bar (full card height, 4dp wide) ── -->
        <View
            android:id="@+id/accentBar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:minHeight="80dp"
            android:background="#00C896"/>

        <!-- ── Icon stack ── -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <!-- Outer ring -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/iconOuter"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                app:cardCornerRadius="28dp"
                app:cardBackgroundColor="#141929"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1E2A3E"/>

            <!-- Inner tinted badge -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/iconHolder"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_gravity="center"
                app:cardCornerRadius="21dp"
                app:cardBackgroundColor="#0D2E1E"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imgType"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:scaleType="centerInside"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- Arrow corner badge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="bottom|end"
                app:cardCornerRadius="9dp"
                app:cardBackgroundColor="#080C18"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imgArrow"
                    android:layout_width="11dp"
                    android:layout_height="11dp"
                    android:layout_gravity="center"
                    android:scaleType="centerInside"/>

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

        <!-- ── Centre: title + chips row + badge ── -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp">

            <!-- Category / source name -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Date chip + type pill row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="7dp">

                <!-- Date chip -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chipSub"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginEnd="7dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#080C18"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#1E2A3E">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <ImageView
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:layout_marginEnd="4dp"
                            android:src="@drawable/ic_calender"
                            android:tint="#3D4E68"/>

                        <TextView
                            android:id="@+id/tvSub"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today · 9:30 AM"
                            android:textColor="#3D4E68"
                            android:textSize="10sp"
                            android:letterSpacing="0.01"/>
                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- INCOME / EXPENSE type pill -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardTypePill"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#0A2018"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <TextView
                        android:id="@+id/tvTypePill"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:paddingStart="9dp"
                        android:paddingEnd="9dp"
                        android:text="INCOME"
                        android:textColor="#00C896"
                        android:textSize="9sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.06"/>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- HIGH SPEND badge (GONE by default) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/badgeCard"
                android:layout_width="wrap_content"
                android:layout_height="22dp"
                android:layout_marginTop="6dp"
                android:visibility="gone"
                app:cardCornerRadius="11dp"
                app:cardBackgroundColor="#1A1608"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2A2210">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:text="HIGH SPEND"
                    android:textColor="#D4A853"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"/>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ── Right: amount (large, prominent) ── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end|center_vertical"
            android:layout_marginEnd="18dp">

            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ ₹0"
                android:textColor="#00C896"
                android:textSize="17sp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

    <!--
        Kept as zero-size so DummyAdapter / TransactionAdapter
        can still findViewById(R.id.dividerRow) without NPE.
        Cards have their own spacing so no visible divider needed.
    -->
    <View
        android:id="@+id/dividerRow"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"/>

</com.google.android.material.card.MaterialCardView>