<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="240dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:backgroundTint="#0B1220"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#1E293B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Accent pill -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDiscoverAccent"
            android:layout_width="42dp"
            android:layout_height="42dp"
            app:cardCornerRadius="21dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#22324A"
            app:cardBackgroundColor="#7C3AED">

            <ImageView
                android:id="@+id/imgDiscoverIcon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="11dp"
                android:src="@drawable/ic_offer"
                android:tint="@android:color/white"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvDiscoverTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Shopping Offers"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvDiscoverSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Best deals on Amazon, Flipkart"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:maxLines="2"
            android:ellipsize="end"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
