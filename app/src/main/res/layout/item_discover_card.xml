<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDiscoverAccent"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_margin="14dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackgroundBorderless"
    app:cardCornerRadius="28dp"
    app:cardElevation="6dp"
    app:strokeWidth="1dp"
    app:strokeColor="#30FFFFFF"
    app:cardBackgroundColor="#111827">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TOP ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- PREMIUM ICON -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_discover_glow_circle"
                android:gravity="center">

                <ImageView
                    android:id="@+id/imgDiscoverIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:scaleType="centerInside"
                    app:tint="@android:color/white"/>
            </FrameLayout>

            <!-- TITLE + SUB -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="14dp">

                <TextView
                    android:id="@+id/tvDiscoverTitle"
                    android:text="Offer Title"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvDiscoverSub"
                    android:text="Offer subtitle here"
                    android:textSize="13sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- DISCOUNT BADGE STYLE -->
        <TextView
            android:id="@+id/tvDiscount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50% OFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_discount_badge"
            android:stateListAnimator="@animator/lift_on_press"
            android:paddingHorizontal="14dp"
            android:paddingVertical="6dp"
            android:layout_marginTop="16dp"/>

        <!-- COUPON CHIP -->
        <TextView
            android:id="@+id/tvCoupon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use Code: SAVE50"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#60A5FA"
            android:background="@drawable/bg_coupon_chip"
            android:paddingHorizontal="14dp"
            android:paddingVertical="8dp"
            android:layout_marginTop="12dp"/>

        <!-- TIMER -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time Left: 2h 30m 10s"
            android:textSize="13sp"
            android:textColor="#F97316"
            android:layout_marginTop="14dp"/>

        <!-- EXPIRY -->
        <TextView
            android:id="@+id/tvExpiryExact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expires on: 18/02/2026 10:18:22"
            android:textSize="12sp"
            android:textColor="#6B7280"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
