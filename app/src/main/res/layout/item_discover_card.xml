<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDiscoverAccent"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="10dp"
    app:cardUseCompatPadding="true"
    app:strokeWidth="1dp"
    app:strokeColor="#20FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp"
        android:background="@drawable/bg_glass_toolbaar">

        <!-- TOP ROW -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/imgDiscoverIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:scaleType="centerCrop"
                android:background="@drawable/circle_bg_blue"
                android:padding="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvDiscoverTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Offer Title"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary_dark"/>

                <TextView
                    android:id="@+id/tvDiscoverSub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Offer subtitle here"
                    android:textSize="13sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- DISCOUNT -->
        <TextView
            android:id="@+id/tvDiscount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50% OFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#22C55E"
            android:layout_marginTop="14dp"/>

        <!-- COUPON -->
        <TextView
            android:id="@+id/tvCoupon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use Code: SAVE50"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#3B82F6"
            android:background="@drawable/glass_border"
            android:padding="8dp"
            android:layout_marginTop="8dp"/>

        <!-- COUNTDOWN -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time Left: 2h 30m 10s"
            android:textSize="13sp"
            android:textColor="#F97316"
            android:layout_marginTop="12dp"/>

        <!-- EXACT EXPIRY -->
        <TextView
            android:id="@+id/tvExpiryExact"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expires on: 18/02/2026 10:18:22"
            android:textSize="12sp"
            android:textColor="@color/text_hint"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
