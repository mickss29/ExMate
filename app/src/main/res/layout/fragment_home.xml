<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080C18">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ╔══════════════════════════════════════════════════════╗ -->
            <!--   HERO HEADER                                           -->
            <!-- ╚══════════════════════════════════════════════════════╝ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#080C18">

                <!-- Soft gold glow behind balance -->
                <View
                    android:layout_width="260dp"
                    android:layout_height="260dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="70dp"
                    android:alpha="0.12"
                    app:background="@drawable/bg_glow_blob"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:paddingTop="22dp"
                    android:paddingBottom="44dp">

                    <!-- ── TOP ROW: Avatar / Greeting / Mic ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            app:cardCornerRadius="21dp"
                            app:cardBackgroundColor="#141929"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#1E2A3E">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="10dp"
                                android:src="@drawable/ic_user"
                                app:tint="#8899B4"/>
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Good day,"
                                android:textColor="#8899B4"
                                android:textSize="11sp"
                                android:letterSpacing="0.04"/>

                            <TextView
                                android:id="@+id/tvUserName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="#FFFFFF"
                                android:textSize="18sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <!-- Gold mic FAB -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/fabVoiceDashboard"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardCornerRadius="22dp"
                            app:cardBackgroundColor="#D4A853"
                            app:cardElevation="12dp">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_btn_speak_now"
                                app:tint="#080C18"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- ── BALANCE HERO ── -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="40dp"
                        android:orientation="vertical"
                        android:gravity="center_horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="N E T   B A L A N C E"
                            android:textColor="#D4A853"
                            android:textSize="9sp"
                            android:letterSpacing="0.25"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvCurrentBalance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="₹ 0"
                            android:textColor="#FFFFFF"
                            android:textSize="50sp"
                            android:textStyle="bold"
                            android:includeFontPadding="false"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Updated just now"
                            android:textColor="#3D4E68"
                            android:textSize="11sp"/>

                        <!-- Income / Expense stat pills -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Income pill -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                android:layout_marginEnd="10dp"
                                app:cardCornerRadius="19dp"
                                app:cardBackgroundColor="#0A2018"
                                app:cardElevation="0dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="#153D2B">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp">

                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_marginEnd="8dp"
                                        app:cardCornerRadius="10dp"
                                        app:cardBackgroundColor="#153D2B"
                                        app:cardElevation="0dp">

                                        <ImageView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:padding="4dp"
                                            android:src="@drawable/ic_arrow_up"
                                            app:tint="#00C896"/>
                                    </com.google.android.material.card.MaterialCardView>

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Income"
                                            android:textColor="#4D8C78"
                                            android:textSize="9sp"
                                            android:letterSpacing="0.04"/>

                                        <TextView
                                            android:id="@+id/tvIncome"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="₹0"
                                            android:textColor="#00C896"
                                            android:textSize="13sp"
                                            android:textStyle="bold"/>
                                    </LinearLayout>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>

                            <!-- Expense pill -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="38dp"
                                app:cardCornerRadius="19dp"
                                app:cardBackgroundColor="#200A0A"
                                app:cardElevation="0dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="#3D1515">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:paddingStart="14dp"
                                    android:paddingEnd="14dp">

                                    <com.google.android.material.card.MaterialCardView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_marginEnd="8dp"
                                        app:cardCornerRadius="10dp"
                                        app:cardBackgroundColor="#3D1515"
                                        app:cardElevation="0dp">

                                        <ImageView
                                            android:layout_width="match_parent"
                                            android:layout_height="match_parent"
                                            android:padding="4dp"
                                            android:src="@drawable/ic_arrow_down"
                                            app:tint="#FF5A5A"/>
                                    </com.google.android.material.card.MaterialCardView>

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="Expenses"
                                            android:textColor="#8C4D4D"
                                            android:textSize="9sp"
                                            android:letterSpacing="0.04"/>

                                        <TextView
                                            android:id="@+id/tvExpense"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="₹0"
                                            android:textColor="#FF5A5A"
                                            android:textSize="13sp"
                                            android:textStyle="bold"/>
                                    </LinearLayout>
                                </LinearLayout>
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </FrameLayout>

            <!-- ╔══════════════════════════════════════════════════════╗ -->
            <!--   BODY SECTION                                          -->
            <!-- ╚══════════════════════════════════════════════════════╝ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#080C18"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <!-- ── Quick Action Buttons ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="26dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAddIncome"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="26dp"
                        app:cardBackgroundColor="#00C896"
                        app:cardElevation="10dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:layout_marginEnd="7dp"
                                android:src="@drawable/ic_arrow_up"
                                app:tint="#000000"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add Income"
                                android:textColor="#000000"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAddExpense"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="26dp"
                        app:cardBackgroundColor="#0F1421"
                        app:cardElevation="0dp"
                        app:strokeWidth="1.5dp"
                        app:strokeColor="#FF5A5A">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:layout_marginEnd="7dp"
                                android:src="@drawable/ic_arrow_down"
                                app:tint="#FF5A5A"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add Expense"
                                android:textColor="#FF5A5A"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- ── Budget Card ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBudgetSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="#0F1421"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#1E2A3E">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Header row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="B U D G E T"
                                    android:textColor="#D4A853"
                                    android:textSize="9sp"
                                    android:letterSpacing="0.2"
                                    android:textStyle="bold"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="Monthly Overview"
                                    android:textColor="#FFFFFF"
                                    android:textSize="16sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:cardCornerRadius="10dp"
                                app:cardBackgroundColor="#0A2018"
                                app:cardElevation="0dp"
                                app:strokeWidth="1dp"
                                app:strokeColor="#153D2B">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:paddingStart="10dp"
                                    android:paddingEnd="10dp"
                                    android:paddingTop="5dp"
                                    android:paddingBottom="5dp"
                                    android:text="On Track ✓"
                                    android:textColor="#00C896"
                                    android:textSize="10sp"
                                    android:textStyle="bold"/>
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="16dp"
                            android:layout_marginBottom="16dp"
                            android:background="#1E2A3E"/>

                        <!-- Amounts row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="14dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Spent"
                                    android:textColor="#8899B4"
                                    android:textSize="11sp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="₹10,000"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:gravity="end">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Remaining"
                                    android:textColor="#8899B4"
                                    android:textSize="11sp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="₹40,000"
                                    android:textColor="#00C896"
                                    android:textSize="20sp"
                                    android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>

                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="7dp"
                            android:max="100"
                            android:progress="20"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progressTint="#00C896"
                            android:progressBackgroundTint="#1E2A3E"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="20% of budget used"
                                android:textColor="#3D4E68"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Limit ₹50,000"
                                android:textColor="#3D4E68"
                                android:textSize="11sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="Full budget breakdown →"
                            android:textColor="#D4A853"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ══ Section Label: Explore ══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="34dp"
                    android:layout_marginBottom="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="10dp"
                        android:background="#D4A853"/>

                    <TextView
                        android:id="@+id/tvDiscoverTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Explore"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="See all"
                        android:textColor="#3D4E68"
                        android:textSize="12sp"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvDiscover"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"/>

                <!-- ══ Section Label: Recent Transactions ══ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="34dp"
                    android:layout_marginBottom="14dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="3dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="10dp"
                        android:background="#D4A853"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent Transactions"
                        android:textColor="#FFFFFF"
                        android:textSize="17sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/btnViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View all"
                        android:textColor="#D4A853"
                        android:textStyle="bold"
                        android:textSize="12sp"/>
                </LinearLayout>

                <!-- Transaction list -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardBackgroundColor="#0F1421"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#1E2A3E">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"/>
                </com.google.android.material.card.MaterialCardView>

                <!-- Bottom nav spacing -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="110dp"/>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>