<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060C1E">

    <!-- ── AMBIENT GLOW ──────────────────────────────────────── -->
    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:alpha="0.10"
        android:background="@drawable/blob_glow_bottom"
        android:layout_gravity="bottom|end"
        android:translationX="60dp"
        android:translationY="60dp" />

    <!-- ═══════════════════════════════════════════════════════
         HEADER
    ═══════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/headerPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/admin_header_bg"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="46dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Back -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="#0D1530"
                app:cardElevation="0dp"
                app:strokeColor="#1A2C52"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="9dp"
                    android:src="@drawable/ic_back"
                    app:tint="#5B8BFF" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Title -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage Offers"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tvOfferCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active discounts &amp; promotions"
                    android:textColor="#2E4470"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- NEW badge -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                app:cardCornerRadius="8dp"
                app:cardBackgroundColor="#041418"
                app:cardElevation="0dp"
                app:strokeColor="#22D3EE"
                app:strokeWidth="1dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏷 Offers"
                        android:textColor="#22D3EE"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════
         RECYCLER
    ═══════════════════════════════════════════════════════ -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerOffers"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="108dp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="90dp"
        android:clipToPadding="false"
        android:scrollbars="none"
        android:overScrollMode="never" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="108dp"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🏷️" android:textSize="44sp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="No offers yet"
            android:textColor="#E2E8F0" android:textSize="16sp" android:textStyle="bold"
            android:layout_marginTop="12dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tap + to create your first offer"
            android:textColor="#2E4470" android:textSize="13sp"
            android:layout_marginTop="6dp" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════
         FAB — Add Offer
    ═══════════════════════════════════════════════════════ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="52dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#0D1F4A"
        app:cardElevation="12dp"
        app:strokeColor="#2B55FF"
        app:strokeWidth="1.5dp"
        android:clickable="true"
        android:focusable="true">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="＋"
                android:textColor="#5B8BFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Offer"
                android:textColor="#5B8BFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>