<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_discover.xml
    Full-screen Discover — dark Obsidian theme matching the dashboard.
    Structure:
      1. Fixed header  (back + title + subtitle)
      2. Horizontal category chips
      3. Section label row
      4. Scrollable offer list  /  shimmer  /  empty state
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#080C18">

    <!-- ═══════════════════════════════════════════
         HEADER
    ═══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="20dp"
        android:background="#080C18">

        <!-- Back + title row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Back button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="14dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#0F1421"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1E2A3E">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_arrow_right"
                    android:rotation="180"
                    android:tint="#8899B4"/>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="E X P L O R E"
                    android:textColor="#D4A853"
                    android:textSize="9sp"
                    android:letterSpacing="0.25"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Discover Offers"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ── Category chips ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/categoryRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:paddingStart="0dp"
            android:paddingEnd="20dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:nestedScrollingEnabled="false"/>

    </LinearLayout>

    <!-- Thin gold divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1E2A3E"/>

    <!-- ═══════════════════════════════════════════
         OFFERS SECTION LABEL
    ═══════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="14dp">

        <View
            android:layout_width="3dp"
            android:layout_height="18dp"
            android:layout_marginEnd="10dp"
            android:background="#D4A853"/>

        <TextView
            android:id="@+id/offerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="All Offers"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvOfferCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#3D4E68"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- ═══════════════════════════════════════════
         CONTENT FRAME  (offers / shimmer / empty)
    ═══════════════════════════════════════════ -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ── Offer list ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/offerRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="24dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:visibility="gone"/>

        <!-- ── Shimmer skeleton ── -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Skeleton card 1 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#0F1421"
                    app:cardElevation="0dp"/>

                <!-- Skeleton card 2 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    android:layout_marginBottom="14dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#0F1421"
                    app:cardElevation="0dp"/>

                <!-- Skeleton card 3 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="110dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#0F1421"
                    app:cardElevation="0dp"/>

            </LinearLayout>

        </com.facebook.shimmer.ShimmerFrameLayout>

        <!-- ── Empty state ── -->
        <LinearLayout
            android:id="@+id/emptyLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Icon circle -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="80dp"
                android:layout_height="80dp"
                app:cardCornerRadius="40dp"
                app:cardBackgroundColor="#0F1421"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1E2A3E">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_offer"
                    android:tint="#3D4E68"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="No offers right now"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Check back later for deals"
                android:textColor="#3D4E68"
                android:textSize="13sp"/>

        </LinearLayout>

    </FrameLayout>

</LinearLayout>