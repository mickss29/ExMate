<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_premium"
    app:layout_constraintHeight_min="400dp">

    <!-- ===== AMBIENT GLOW TOP (decorative) ===== -->
    <View
        android:id="@+id/glowTop"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:alpha="0.22"
        android:background="@drawable/blob_glow_top"
        android:translationX="-60dp"
        android:translationY="-80dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ===== AMBIENT GLOW BOTTOM (decorative) ===== -->
    <View
        android:id="@+id/glowBottom"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:alpha="0.16"
        android:background="@drawable/blob_glow_bottom"
        android:translationX="60dp"
        android:translationY="60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ===== BRAND HEADER ===== -->
    <LinearLayout
        android:id="@+id/layoutBrand"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="56dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Logo Card with glow ring -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLogo"
            android:layout_width="72dp"
            android:layout_height="72dp"
            app:cardBackgroundColor="#0D1B3E"
            app:cardCornerRadius="24dp"
            app:cardElevation="24dp"
            app:strokeColor="#2A4080"
            app:strokeWidth="1.5dp">

            <ImageView
                android:id="@+id/imgLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:scaleType="fitCenter"
                android:src="@drawable/exmate_logo" />
        </com.google.android.material.card.MaterialCardView>

        <!-- App Name -->
        <TextView
            android:id="@+id/tvBrandName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:letterSpacing="0.04"

            android:text="ExMate"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- Tagline with dot separators -->
        <TextView
            android:id="@+id/tvBrandTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:letterSpacing="0.06"
            android:text="SAVE BETTER  ·  SPEND SMARTER"
            android:textColor="#6B8FD4"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- ===== FOOTER ===== -->
    <LinearLayout
        android:id="@+id/layoutFooter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/dot_green_pulse"
            android:layout_marginEnd="7dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.04"
            android:text="Secure · Encrypted · Private"
            android:textColor="#4A6098"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- ===== MAIN AUTH CARD ===== -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/containerCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="#080F24"
        app:cardCornerRadius="32dp"
        app:cardElevation="32dp"
        app:strokeColor="#162040"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/layoutFooter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutBrand">

        <!-- Subtle top inner glow line -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/card_top_shimmer"
            android:layout_gravity="top" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/cardScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layoutMainAuth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="26dp"
                android:paddingEnd="26dp"
                android:paddingTop="28dp"
                android:paddingBottom="28dp">

                <!-- === SECTION TITLE === -->
                <TextView
                    android:id="@+id/tvAuthTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Welcome back"

                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAuthSub"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Sign in to continue tracking smarter"
                    android:textColor="#5570A0"
                    android:textSize="13sp" />

                <!-- === PREMIUM TOGGLE === -->
                <FrameLayout
                    android:id="@+id/toggleContainer"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/toggle_track_bg"
                    android:padding="4dp">

                    <!-- Sliding pill indicator -->
                    <View
                        android:id="@+id/toggleIndicator"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="start"
                        android:background="@drawable/toggle_pill_active" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <TextView
                            android:id="@+id/tabLogin"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"


                            android:gravity="center"
                            android:text="Login"
                            android:textColor="#FFFFFF"
                            android:textSize="13.5sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tabSignup"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"


                            android:gravity="center"
                            android:text="Sign Up"
                            android:textColor="#3D5580"
                            android:textSize="13.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </FrameLayout>

                <!-- ========== LOGIN SECTION ========== -->
                <LinearLayout
                    android:id="@+id/layoutLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <!-- Email Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilLoginEmail"
                        style="@style/PremiumInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email address"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="#3D5A94">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLoginEmail"
                            style="@style/PremiumInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textEmailAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Field -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilLoginPassword"
                        style="@style/PremiumInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Password"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#3D5A94"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="#3D5A94">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etLoginPassword"
                            style="@style/PremiumInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Forgot Password -->
                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:text="Forgot password?"
                        android:textColor="#5B8BFF"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <!-- Login Button - PREMIUM GRADIENT -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/btn_premium_gradient"
                        android:backgroundTint="@android:color/transparent"

                        android:letterSpacing="0.03"
                        android:stateListAnimator="@null"
                        android:text="Log in"

                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_arrow_right"
                        app:iconGravity="textEnd"
                        app:iconPadding="10dp"
                        app:iconTint="@android:color/white" />

                    <!-- Divider OR -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@drawable/divider_fade" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_marginEnd="14dp"
                            android:text="or"
                            android:textColor="#2A3E66"
                            android:textSize="12sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@drawable/divider_fade_reverse" />
                    </LinearLayout>

                    <!-- Trust Badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/badge_trust_bg"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔒"
                            android:textSize="12sp"
                            android:layout_marginEnd="6dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your data stays private with you"
                            android:textColor="#4A6898"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Switch to Signup hint -->
                    <LinearLayout
                        android:id="@+id/swipeHintLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Don't have an account? "
                            android:textColor="#2E4470"
                            android:textSize="12.5sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sign Up →"
                            android:textColor="#5B8BFF"
                            android:textSize="12.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ========== SIGNUP SECTION ========== -->
                <LinearLayout
                    android:id="@+id/layoutSignup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Full Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilFullName"
                        style="@style/PremiumInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Full name"
                        app:startIconDrawable="@drawable/ic_user"
                        app:startIconTint="#3D5A94">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etFullName"
                            style="@style/PremiumInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="56dp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilSignupEmail"
                        style="@style/PremiumInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Email address"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="#3D5A94">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSignupEmail"
                            style="@style/PremiumInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textEmailAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilSignupPassword"
                        style="@style/PremiumInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Password"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#3D5A94"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="#3D5A94">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSignupPassword"
                            style="@style/PremiumInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirm Password -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilConfirmPassword"
                        style="@style/PremiumInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="Confirm password"
                        app:endIconMode="password_toggle"
                        app:endIconTint="#3D5A94"
                        app:startIconDrawable="@drawable/ic_lock"
                        app:startIconTint="#3D5A94">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSignupConfirmPassword"
                            style="@style/PremiumInputEditText"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Strength Bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:weightSum="4"
                        android:id="@+id/passwordStrengthBar">

                        <View android:id="@+id/strengthBar1"
                            android:layout_width="0dp" android:layout_height="3dp"
                            android:layout_weight="1" android:layout_marginEnd="3dp"
                            android:background="@drawable/strength_bar_inactive"
                            android:backgroundTint="#1A2540"/>
                        <View android:id="@+id/strengthBar2"
                            android:layout_width="0dp" android:layout_height="3dp"
                            android:layout_weight="1" android:layout_marginEnd="3dp"
                            android:background="@drawable/strength_bar_inactive"
                            android:backgroundTint="#1A2540"/>
                        <View android:id="@+id/strengthBar3"
                            android:layout_width="0dp" android:layout_height="3dp"
                            android:layout_weight="1" android:layout_marginEnd="3dp"
                            android:background="@drawable/strength_bar_inactive"
                            android:backgroundTint="#1A2540"/>
                        <View android:id="@+id/strengthBar4"
                            android:layout_width="0dp" android:layout_height="3dp"
                            android:layout_weight="1"
                            android:background="@drawable/strength_bar_inactive"
                            android:backgroundTint="#1A2540"/>
                    </LinearLayout>

                    <!-- Create Account Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSignup"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="22dp"
                        android:background="@drawable/btn_premium_gradient"
                        android:backgroundTint="@android:color/transparent"

                        android:letterSpacing="0.03"
                        android:stateListAnimator="@null"
                        android:text="Create Account"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:cornerRadius="18dp"
                        app:icon="@drawable/ic_arrow_right"
                        app:iconGravity="textEnd"
                        app:iconPadding="10dp"
                        app:iconTint="@android:color/white" />

                    <!-- Terms text -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="14dp"
                        android:gravity="center"
                        android:text="By signing up, you agree to our Terms &amp; Privacy Policy"
                        android:textColor="#2A3E66"
                        android:textSize="11sp" />

                    <!-- Switch to Login hint -->
                    <LinearLayout
                        android:id="@+id/swipeHintSignup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Already have an account? "
                            android:textColor="#2E4470"
                            android:textSize="12.5sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="← Login"
                            android:textColor="#5B8BFF"
                            android:textSize="12.5sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>