<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/bottom_nav_item_bg.xml
     Active item gets a blue gradient pill,
     inactive items stay transparent.
     Works with Theme.MaterialComponents (no Material3 needed). -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Active / checked state — blue gradient pill -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#1A3BCC"
                android:endColor="#2B55FF" />
            <corners android:radius="14dp" />
        </shape>
    </item>

    <!-- All other states — transparent -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</selector>