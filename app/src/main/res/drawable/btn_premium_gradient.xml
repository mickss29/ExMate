<?xml version="1.0" encoding="utf-8"?>
<!-- btn_premium_gradient.xml
     Premium CTA button — vibrant blue to royal purple gradient with depth -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed state — slightly darker/scaled -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#1230AA"
                android:centerColor="#2040CC"
                android:endColor="#3A1FAA" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <!-- Normal state -->
    <item>
        <layer-list>
            <!-- Shadow layer -->
            <item
                android:left="2dp"
                android:top="4dp"
                android:right="2dp"
                android:bottom="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="#331A44FF" />
                    <corners android:radius="18dp" />
                </shape>
            </item>
            <!-- Main gradient -->
            <item android:bottom="4dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:type="linear"
                        android:angle="135"
                        android:startColor="#1E44EE"
                        android:centerColor="#2B55FF"
                        android:endColor="#5533CC" />
                    <corners android:radius="18dp" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>