<?xml version="1.0" encoding="utf-8"?>
<!-- Place this in: res/drawable/chip_bg_dark.xml -->
<!-- Used by the Quick Amount Chips in both fragments -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#2563EB"/>
            <corners android:radius="16dp"/>
            <stroke android:width="1dp" android:color="#3B82F6"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1F2A44"/>
            <corners android:radius="16dp"/>
            <stroke android:width="1dp" android:color="#334155"/>
        </shape>
    </item>
</selector>