<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/chip_income_bg.xml -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#065F46"/>
            <corners android:radius="17dp"/>
            <stroke android:width="1dp" android:color="#34D399"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0D2818"/>
            <corners android:radius="17dp"/>
            <stroke android:width="1dp" android:color="#134E35"/>
        </shape>
    </item>
</selector>